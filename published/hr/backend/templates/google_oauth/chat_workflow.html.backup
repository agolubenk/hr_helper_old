            <script src="{% static 'js/vacancy-slots.js' %}"></script>
            
            <script>
            // Настройки пользователя для рабочих часов
            window.userWorkHours = {
                startHour: {{ user.interview_start_time.hour|default:11 }},
                endHour: {{ user.interview_end_time.hour|default:18 }}
            };
            
            // Время между встречами пользователя (в минутах)
            window.userMeetingInterval = {{ user.meeting_interval_minutes|default:15 }};
            </script>
            
            <script>
            // Функция для переключения карточки слотов по клику на бейдж
            function toggleSlotsCard() {
                console.log('🔄 toggleSlotsCard вызвана');
                const slotsCardBody = document.getElementById('slotsCardBody');
                const collapseButton = document.querySelector('[data-bs-target="#slotsCardBody"]');
                
                console.log('🔍 slotsCardBody найден:', !!slotsCardBody);
                console.log('🔍 collapseButton найден:', !!collapseButton);
                console.log('🔍 slotsCardBody элемент:', slotsCardBody);
                
                if (slotsCardBody) {
                    // Проверяем текущее состояние
                    const isCollapsed = slotsCardBody.classList.contains('collapse') && !slotsCardBody.classList.contains('show');
                    console.log('🔍 Карточка свернута:', isCollapsed);
                    
                    // Пробуем Bootstrap Collapse
                    if (typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
                        const bsCollapse = new bootstrap.Collapse(slotsCardBody, {
                            toggle: true
                        });
                        console.log('✅ Bootstrap Collapse инициализирован');
                    } else {
                        // Альтернативный способ без Bootstrap
                        console.log('⚠️ Bootstrap недоступен, используем альтернативный способ');
                        if (slotsCardBody.classList.contains('show')) {
                            slotsCardBody.classList.remove('show');
                            slotsCardBody.style.display = 'none';
                        } else {
                            slotsCardBody.classList.add('show');
                            slotsCardBody.style.display = 'block';
                        }
                        console.log('✅ Альтернативное переключение выполнено');
                    }
                } else {
                    console.error('❌ Элемент slotsCardBody не найден!');
                }
            }
            
            // Добавляем стили для кликабельного бейджа
            document.addEventListener('DOMContentLoaded', function() {
                // Проверяем, что Bootstrap загружен
                console.log('🔍 Bootstrap доступен:', typeof bootstrap !== 'undefined');
                console.log('🔍 Bootstrap.Collapse доступен:', typeof bootstrap?.Collapse !== 'undefined');
                
                const clickableBadges = document.querySelectorAll('.clickable-badge');
                console.log('🔍 Кликабельные бейджи найдены:', clickableBadges.length);
                
                clickableBadges.forEach(function(clickableBadge) {
                    // Добавляем hover эффект
                    clickableBadge.addEventListener('mouseenter', function() {
                        this.style.transform = 'scale(1.05)';
                        this.style.transition = 'transform 0.2s ease';
                    });
                    
                    clickableBadge.addEventListener('mouseleave', function() {
                        this.style.transform = 'scale(1)';
                    });
                    
                    // Добавляем активный эффект при клике
                    clickableBadge.addEventListener('mousedown', function() {
                        this.style.transform = 'scale(0.95)';
                    });
                    
                    clickableBadge.addEventListener('mouseup', function() {
                        this.style.transform = 'scale(1.05)';
                    });
                });
            });
            
            
            // Функция для переключения карточки команд
            function toggleCommandsCard() {
                console.log('🔄 toggleCommandsCard вызвана');
                const commandsCardBody = document.getElementById('commandsCardBody');
                const toggleIcon = document.getElementById('commandsToggleIcon');
                const commandsList = commandsCardBody ? commandsCardBody.querySelector('.commands-list') : null;
                
                if (commandsList) {
                    // Проверяем, свернута ли карточка (есть ли класс collapsed)
                    const isCollapsed = commandsList.classList.contains('collapsed');
                    
                    if (isCollapsed) {
                        // Разворачиваем - показываем все команды
                        commandsList.classList.remove('collapsed');
                        toggleIcon.className = 'fas fa-chevron-up';
                        console.log('📖 Команды развернуты');
                    } else {
                        // Сворачиваем - показываем 2.5 команды с градиентом
                        commandsList.classList.add('collapsed');
                        toggleIcon.className = 'fas fa-chevron-down';
                        console.log('📕 Команды свернуты');
                    }
                }
            }
            
            // === ДИНАМИЧЕСКАЯ ВЫСОТА ЧАТА ===
            function calculateChatHeight() {
                const chatMessages = document.getElementById('chat-messages');
                if (!chatMessages) return;
                
                // Получаем высоту окна
                const windowHeight = window.innerHeight;
                
                // Вычисляем высоту только тех элементов, которые влияют на вертикальное пространство
                const stickyHeader = document.querySelector('.sticky-top');
                const vacancySelector = document.querySelector('.vacancy-selector');
                const chatCard = document.querySelector('.card');
                const chatHeader = chatCard ? chatCard.querySelector('.card-header') : null;
                const chatInput = chatCard ? chatCard.querySelector('.card-footer') : null;
                
                // Вычисляем общую высоту элементов
                let usedHeight = 0;
                
                if (stickyHeader) {
                    usedHeight += stickyHeader.offsetHeight;
                }
                
                if (vacancySelector) {
                    usedHeight += vacancySelector.offsetHeight + 20; // +20px для margin
                }
                
                if (chatHeader) {
                    usedHeight += chatHeader.offsetHeight;
                }
                
                if (chatInput) {
                    usedHeight += chatInput.offsetHeight;
                }
                
                // Добавляем отступы и padding
                usedHeight += 40; // Общие отступы
                
                // Вычисляем доступную высоту для чата
                const availableHeight = windowHeight - usedHeight;
                
                // Устанавливаем минимальную и максимальную высоту
                const minHeight = 300;
                const maxHeight = windowHeight - 200;
                const finalHeight = Math.max(minHeight, Math.min(maxHeight, availableHeight));
                
                // Применяем высоту только если она действительно изменилась
                const currentHeight = parseInt(chatMessages.style.height) || 0;
                if (Math.abs(currentHeight - finalHeight) > 5) { // Только если разница больше 5px
                    chatMessages.style.height = finalHeight + 'px';
                    
                    console.log('📏 Динамическая высота чата:', {
                        windowHeight,
                        usedHeight,
                        availableHeight,
                        finalHeight,
                        currentHeight
                    });
                }
            }
            
            // Вызываем расчет при загрузке
            calculateChatHeight();
            
            // Обработчик resize с дебаунсом для предотвращения частых вызовов
            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    const newHeight = window.innerHeight;
                    // Пересчитываем только если изменилась высота окна
                    if (Math.abs(newHeight - (window.lastHeight || 0)) > 10) {
                        calculateChatHeight();
                        window.lastHeight = newHeight;
                    }
                }, 100);
            });
            
            // Инициализация состояния карточки команд (свернутое состояние по умолчанию)
            document.addEventListener('DOMContentLoaded', function() {
                const commandsCardBody = document.getElementById('commandsCardBody');
                const toggleIcon = document.getElementById('commandsToggleIcon');
                const commandsList = commandsCardBody ? commandsCardBody.querySelector('.commands-list') : null;
                
                if (commandsList && toggleIcon) {
                    // Устанавливаем свернутое состояние по умолчанию
                    commandsList.classList.add('collapsed');
                    toggleIcon.className = 'fas fa-chevron-down';
                    console.log('📕 Карточка команд инициализирована в свернутом состоянии');
                }
            });
            
            </script>
            
            
            <!-- Подключение скрипта автоматических меток -->
            <script>
                // Передаем sessionId из контекста шаблона в глобальный scope
                window.sessionId = {{ chat_session.id }};
            </script>
            <script src="{% static 'js/chat_actions.js' %}"></script>
            
            <!-- ПРИНУДИТЕЛЬНЫЕ СТИЛИ ДЛЯ ОГРАНИЧЕНИЯ ШИРИНЫ СООБЩЕНИЙ -->
            <style>
                /* Максимально специфичные селекторы для принудительного ограничения ширины */
                .card .chat-messages .message.user-message .message-bubble,
                .card .chat-messages .user-message .message-bubble,
                .card .user-message .message-bubble,
                .user-message .message-bubble,
                .message.user-message .message-bubble {
                    max-width: 75% !important;
                    width: 75% !important;
                    min-width: 120px !important;
                    word-wrap: break-word !important;
                    word-break: break-word !important;
                    overflow-wrap: break-word !important;
                    white-space: normal !important;
                    hyphens: auto !important;
                    box-sizing: border-box !important;
                }

                .card .chat-messages .message.system-message .message-bubble,
                .card .chat-messages .system-message .message-bubble,
                .card .system-message .message-bubble,
                .system-message .message-bubble,
                .message.system-message .message-bubble {
                    max-width: 80% !important;
                    width: 80% !important;
                    min-width: fit-content !important;
                    word-wrap: break-word !important;
                    word-break: break-word !important;
                    overflow-wrap: break-word !important;
                    white-space: normal !important;
                    hyphens: auto !important;
                    box-sizing: border-box !important;
                }

                /* Принудительные стили для содержимого сообщений */
                .card .chat-messages .message .message-content,
                .card .chat-messages .message-content,
                .message .message-content,
                .message-content {
                    word-wrap: break-word !important;
                    word-break: break-word !important;
                    overflow-wrap: break-word !important;
                    white-space: normal !important;
                    hyphens: auto !important;
                    max-width: 100% !important;
                    overflow: hidden !important;
                }

                /* АДАПТИВНАЯ ШИРИНА ДЛЯ СООБЩЕНИЙ БОТА С ФУНКЦИОНАЛЬНЫМИ КНОПКАМИ */
                .card .chat-messages .message.system-message .message-bubble,
                .card .chat-messages .system-message .message-bubble,
                .card .system-message .message-bubble,
                .system-message .message-bubble,
                .message.system-message .message-bubble {
                    width: auto !important;
                    max-width: 80% !important;
                    min-width: fit-content !important;
                }

                /* Контейнер с информацией и кнопками - адаптивная ширина */
                .card .message-body-with-buttons {
                    display: flex !important;
                    align-items: flex-start !important;
                    gap: 12px !important;
                    width: auto !important;
                    min-width: fit-content !important;
                    max-width: none !important;
                }

                /* Информационная часть - занимает только необходимое место */
                .card .message-info {
                    flex: 0 0 auto !important;
                    min-width: fit-content !important;
                    max-width: none !important;
                }

                /* Кнопки действий - фиксированный размер */
                .card .action-buttons-right {
                    display: flex !important;
                    flex-direction: column !important;
                    gap: 4px !important;
                    flex-shrink: 0 !important;
                    align-self: flex-start !important;
                    margin-top: 2px !important;
                    width: auto !important;
                    min-width: fit-content !important;
                }

                /* Табличная структура - адаптивная ширина */
                .card .candidate-info-table {
                    display: table !important;
                    width: auto !important;
                    min-width: fit-content !important;
                    max-width: none !important;
                    border-spacing: 0 !important;
                    border-collapse: collapse !important;
                    margin-bottom: 6px !important;
                }

                /* Строки таблицы - адаптивная ширина */
                .card .info-row-table {
                    display: table-row !important;
                    width: auto !important;
                }

                /* Лейблы - фиксированная ширина */
                .card .info-label-table {
                    display: table-cell !important;
                    font-weight: 600 !important;
                    color: var(--hr-text, #333) !important;
                    padding-right: 8px !important;
                    white-space: nowrap !important;
                    vertical-align: top !important;
                    line-height: 1.3 !important;
                    font-size: 0.9rem !important;
                    min-width: 65px !important;
                    width: auto !important;
                }

                /* Значения - адаптивная ширина */
                .card .info-value-table {
                    display: table-cell !important;
                    white-space: nowrap !important;
                    vertical-align: top !important;
                    line-height: 1.3 !important;
                    font-size: 0.9rem !important;
                    width: auto !important;
                    min-width: fit-content !important;
                }
            }

            /* === СТИЛИ ДЛЯ КАРТОЧКИ КОМАНД === */
            .commands-list {
                position: relative;
                transition: all 0.3s ease;
            }

            /* Свернутое состояние - показываем 2.5 команды с градиентом */
            .commands-list.collapsed {
                max-height: 280px; /* Высота для 2.5 команд */
                overflow: hidden;
                position: relative;
            }

            /* Градиентный эффект внизу для показа, что есть еще контент */
            .commands-list.collapsed::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 40px;
                background: linear-gradient(transparent, rgba(255, 255, 255, 0.9));
                pointer-events: none;
                z-index: 1;
            }

            /* Темная тема - градиент для темного фона */
            [data-theme="dark"] .commands-list.collapsed::after {
                background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
            }

            /* Стили для команд */
            .command-item {
                transition: all 0.3s ease;
            }


            .command-header {
                display: flex;
                align-items: center;
                margin-bottom: 8px;
            }

            .command-example code {
                background-color: #f8f9fa;
                padding: 4px 6px;
                border-radius: 3px;
                font-size: 0.85rem;
                line-height: 1.4;
            }

            /* Темная тема для кода */
            [data-theme="dark"] .command-example code {
                background-color: #2d3748;
                color: #e2e8f0;
            }
            </style>
            {% endblock %}