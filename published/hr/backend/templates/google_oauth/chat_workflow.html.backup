<!-- Отладочная информация для событий календаря -->
<script>
        flexDiv.className = 'd-flex justify-content-start';
        
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        avatarDiv.innerHTML = `
            <img src="{% static 'img/logo-light.png' %}" alt="HR Helper" class="ai-avatar-image light-theme-logo">
            <img src="{% static 'img/logo-dark.png' %}" alt="HR Helper" class="ai-avatar-image dark-theme-logo">
        `;
        
        const bubbleDiv = document.createElement('div');
        bubbleDiv.className = 'message-bubble system-bubble';
        bubbleDiv.innerHTML = `
            <div class="message-header">
                <strong>HR-скрининг</strong>
                <small class="text-muted ms-2">${new Date().toLocaleString('ru-RU')}</small>
            </div>
            <div class="message-content">
                <div class="message-body-with-buttons">
                    <div class="message-info">
                        <div class="candidate-info-table">
                            <div class="info-row-table">
                                <div class="info-label-table">Кандидат:</div>
                                <div class="info-value-table">${metadata.candidate_name}</div>
                            </div>
                            <div class="info-row-table">
                                <div class="info-label-table">Вакансия:</div>
                                <div class="info-value-table">${metadata.vacancy_name}</div>
                            </div>
                            <div class="info-row-table">
                                <div class="info-label-table">Уровень:</div>
                                <div class="info-value-table">
                                    <span class="badge bg-primary">${metadata.determined_grade}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="action-buttons-right">
                        <a href="${metadata.candidate_url}" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-external-link-alt me-1"></i>Открыть
                        </a>
                    </div>
                </div>
            </div>
        `;
        
        flexDiv.appendChild(avatarDiv);
        flexDiv.appendChild(bubbleDiv);
        messageDiv.appendChild(flexDiv);
        chatMessages.insertBefore(messageDiv, document.getElementById('typing-indicator'));
        
        scrollToBottom();
    }
    
    // Добавление сообщения инвайта
    function addInviteMessage(metadata) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'message mb-3 system-message invite-message';
        
        const flexDiv = document.createElement('div');
        flexDiv.className = 'd-flex justify-content-start';
        
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        avatarDiv.innerHTML = `
            <img src="{% static 'img/logo-light.png' %}" alt="HR Helper" class="ai-avatar-image light-theme-logo">
            <img src="{% static 'img/logo-dark.png' %}" alt="HR Helper" class="ai-avatar-image dark-theme-logo">
        `;
        
        const bubbleDiv = document.createElement('div');
        bubbleDiv.className = 'message-bubble system-bubble';
        bubbleDiv.innerHTML = `
            <div class="message-header">
                <strong>Инвайт</strong>
                <small class="text-muted ms-2">${new Date().toLocaleString('ru-RU')}</small>
            </div>
            <div class="message-content">
                <div class="message-body-with-buttons">
                    <div class="message-info">
                        <div class="candidate-info-table">
                            <div class="info-row-table">
                                <div class="info-label-table">Кандидат:</div>
                                <div class="info-value-table">${metadata.candidate_name}</div>
                            </div>
                            <div class="info-row-table">
                                <div class="info-label-table">Вакансия:</div>
                                <div class="info-value-table">${metadata.vacancy_name}</div>
                            </div>
                            <div class="info-row-table">
                                <div class="info-label-table">Интервьюер:</div>
                                <div class="info-value-table">${metadata.interviewer_name || 'Не указан'}</div>
                            </div>
                            <div class="info-row-table">
                                <div class="info-label-table">Дата интервью:</div>
                                <div class="info-value-table">${metadata.interview_datetime ? new Date(metadata.interview_datetime).toLocaleString('ru-RU') : 'Не указана'}</div>
                            </div>
                        </div>
                    </div>
                    <div class="action-buttons-right">
                        <a href="${metadata.candidate_url}" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-external-link-alt me-1"></i>Открыть
                        </a>
                        ${metadata.calendar_event_url ? `<a href="${metadata.calendar_event_url}" target="_blank" class="btn btn-sm btn-outline-success">
                            <i class="fas fa-calendar me-1"></i>Присоединиться
                        </a>` : ''}
                    </div>
                </div>
            </div>
        `;
        
        flexDiv.appendChild(avatarDiv);
        flexDiv.appendChild(bubbleDiv);
        messageDiv.appendChild(flexDiv);
        chatMessages.insertBefore(messageDiv, document.getElementById('typing-indicator'));
        
        scrollToBottom();
    }
    
    // Автоматическое изменение размера textarea (1-12 строк)
    messageInput.addEventListener('input', function() {
        this.style.height = 'auto';
        const maxHeight = 48 * 12; // 12 строк * 48px на строку
        const newHeight = Math.min(this.scrollHeight, maxHeight);
        this.style.height = newHeight + 'px';
        
        // Обработка команд (только рабочие команды)
        const message = this.value.trim();
        const actionTypeField = document.getElementById('actionType');
        
        if (message.startsWith('/s ')) {
            actionTypeField.value = 'hrscreening';
        } else if (message.startsWith('/in ')) {
            actionTypeField.value = 'invite';
        } else {
            // Не устанавливаем значение по умолчанию - пусть backend сам определит
            actionTypeField.value = '';
        }
    });
    
    // Отправка по Enter (без Shift)
    messageInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            chatForm.submit();
        }
    });
    
    // Автодополнение интервьюеров
    let autocompleteTimeout;
    let currentAutocompleteIndex = -1;
    let currentAutocompleteResults = [];
    
    messageInput.addEventListener('input', function() {
        const value = this.value;
        const cursorPos = this.selectionStart;
        console.log('🔍 INPUT_EVENT: Value:', value, 'Cursor:', cursorPos);
        console.log('🔍 INPUT_EVENT: Message input element:', this);

        // Ищем @ в тексте перед курсором
        const textBeforeCursor = value.substring(0, cursorPos);
        const lastAtIndex = textBeforeCursor.lastIndexOf('@');
        console.log('🔍 INPUT_EVENT: Text before cursor:', textBeforeCursor, 'Last @ index:', lastAtIndex);

        if (lastAtIndex !== -1) {
            const textAfterAt = textBeforeCursor.substring(lastAtIndex + 1);
            console.log('🔍 INPUT_EVENT: Text after @:', textAfterAt);

            // Проверяем, что после @ нет пробелов (значит это начало упоминания)
            if (!textAfterAt.includes(' ') && !textAfterAt.includes('\n')) {
                const query = textAfterAt;
                console.log('🔍 INPUT_EVENT: Query for autocomplete:', query);

                // Очищаем предыдущий таймаут
                clearTimeout(autocompleteTimeout);

                // Устанавливаем новый таймаут для запроса
                autocompleteTimeout = setTimeout(() => {
                    fetchInterviewers(query);
                }, 300); // Задержка 300мс

                return;
            }
        }

        // Скрываем автодополнение, если нет @
        console.log('🔍 INPUT_EVENT: Hiding autocomplete');
        hideAutocomplete();
    });
    
    // Обработка клавиш для навигации по автодополнению
    messageInput.addEventListener('keydown', function(e) {
        const autocomplete = document.getElementById('interviewers-autocomplete');
        
        if (autocomplete.style.display === 'block') {
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                navigateAutocomplete(1);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                navigateAutocomplete(-1);
            } else if (e.key === 'Enter' && currentAutocompleteIndex >= 0) {
                e.preventDefault();
                selectAutocompleteItem(currentAutocompleteResults[currentAutocompleteIndex]);
            } else if (e.key === 'Escape') {
                hideAutocomplete();
            }
        }
    });
    
    // Скрытие автодополнения при клике вне его
    document.addEventListener('click', function(e) {
        const autocomplete = document.getElementById('interviewers-autocomplete');
        if (!autocomplete.contains(e.target) && e.target !== messageInput) {
            hideAutocomplete();
        }
    });
    
    function fetchInterviewers(query) {
        console.log('🔍 FETCH_INTERVIEWERS: Запрос:', query);
        const vacancyId = new URLSearchParams(window.location.search).get('vacancy_id');
        console.log('🔍 FETCH_INTERVIEWERS: Vacancy ID:', vacancyId);
        console.log('🔍 FETCH_INTERVIEWERS: Current URL:', window.location.href);
        
        if (!vacancyId) {
            console.log('❌ FETCH_INTERVIEWERS: Нет vacancy_id');
            hideAutocomplete();
            return;
        }
        
        const url = `/google-oauth/api/interviewers-autocomplete/?vacancy_id=${vacancyId}&q=${encodeURIComponent(query)}`;
        console.log('🔍 FETCH_INTERVIEWERS: URL:', url);
        
        fetch(url, {
            method: 'GET',
            headers: {
                'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value,
                'Content-Type': 'application/json',
            }
        })
            .then(response => {
                console.log('🔍 FETCH_INTERVIEWERS: Response status:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('🔍 FETCH_INTERVIEWERS: Response data:', data);
                console.log('🔍 FETCH_INTERVIEWERS: data.success:', data.success);
                console.log('🔍 FETCH_INTERVIEWERS: data.results:', data.results);
                console.log('🔍 FETCH_INTERVIEWERS: data.results.length:', data.results ? data.results.length : 'undefined');
                if (data.success && data.results.length > 0) {
                    console.log('🔍 FETCH_INTERVIEWERS: Calling showAutocomplete');
                    showAutocomplete(data.results);
                } else {
                    console.log('🔍 FETCH_INTERVIEWERS: Calling hideAutocomplete');
                    hideAutocomplete();
                }
            })
            .catch(error => {
                console.error('❌ FETCH_INTERVIEWERS: Ошибка загрузки интервьюеров:', error);
                hideAutocomplete();
            });
    }
    
    function showAutocomplete(results) {
        console.log('🔍 SHOW_AUTOCOMPLETE: Results:', results);
        console.log('🔍 SHOW_AUTOCOMPLETE: Showing autocomplete dropdown');
        currentAutocompleteResults = results;
        currentAutocompleteIndex = -1;
        
        const autocomplete = document.getElementById('interviewers-autocomplete');
        const list = autocomplete.querySelector('.autocomplete-list');
        
        list.innerHTML = '';
        
        results.forEach((interviewer, index) => {
            const item = document.createElement('div');
            item.className = 'autocomplete-item';
            item.dataset.index = index;
            
            item.innerHTML = `
                <span class="autocomplete-username">${interviewer.username}</span>
                <span class="autocomplete-name">${interviewer.full_name}</span>
                <span class="autocomplete-email">${interviewer.email}</span>
            `;
            
            item.addEventListener('click', () => selectAutocompleteItem(interviewer));
            list.appendChild(item);
        });
        
        autocomplete.style.display = 'block';
    }
    
    function hideAutocomplete() {
        console.log('🔍 HIDE_AUTOCOMPLETE: Hiding autocomplete dropdown');
        const autocomplete = document.getElementById('interviewers-autocomplete');
        autocomplete.style.display = 'none';
        currentAutocompleteResults = [];
        currentAutocompleteIndex = -1;
    }
    
    function navigateAutocomplete(direction) {
        if (currentAutocompleteResults.length === 0) return;
        
        // Убираем активный класс с текущего элемента
        const items = document.querySelectorAll('.autocomplete-item');
        if (currentAutocompleteIndex >= 0) {
            items[currentAutocompleteIndex].classList.remove('active');
        }
        
        // Вычисляем новый индекс
        currentAutocompleteIndex += direction;
        
        if (currentAutocompleteIndex < 0) {
            currentAutocompleteIndex = currentAutocompleteResults.length - 1;
        } else if (currentAutocompleteIndex >= currentAutocompleteResults.length) {
            currentAutocompleteIndex = 0;
        }
        
        // Добавляем активный класс к новому элементу
        items[currentAutocompleteIndex].classList.add('active');
    }
    
    function selectAutocompleteItem(interviewer) {
        console.log('🔍 SELECT_AUTOCOMPLETE: Выбран интервьюер:', interviewer);
        
        const value = messageInput.value;
        const cursorPos = messageInput.selectionStart;
        
        // Находим позицию @
        const textBeforeCursor = value.substring(0, cursorPos);
        const lastAtIndex = textBeforeCursor.lastIndexOf('@');
        
        if (lastAtIndex !== -1) {
            // Заменяем текст от @ до курсора на username интервьюера
            const newValue = value.substring(0, lastAtIndex) + interviewer.username + ' ' + value.substring(cursorPos);
            messageInput.value = newValue;
            
            // Устанавливаем курсор после username
            const newCursorPos = lastAtIndex + interviewer.username.length + 1;
            messageInput.setSelectionRange(newCursorPos, newCursorPos);
            
            // Добавляем информацию об интервьюере в скрытое поле для отправки на сервер
            const interviewerInfo = document.createElement('input');
            interviewerInfo.type = 'hidden';
            interviewerInfo.name = 'selected_interviewer';
            interviewerInfo.value = JSON.stringify({
                id: interviewer.id,
                username: interviewer.username,
                email: interviewer.email,
                full_name: interviewer.full_name
            });
            
            // Добавляем в форму, если её нет - создаем
            let chatForm = document.getElementById('chat-form');
            if (!chatForm) {
                chatForm = messageInput.closest('form');
            }
            chatForm.appendChild(interviewerInfo);
        }
        
        hideAutocomplete();
        messageInput.focus();
    }
    
    
    // Фокус на поле ввода (убираем автоматический фокус при загрузке)
    // messageInput.focus();
    
    
    // Hover эффекты теперь обрабатываются через CSS, JavaScript не нужен
    
    // Копирование текста инвайта
    document.addEventListener('click', function(e) {
        if (e.target.closest('.copy-invitation-btn')) {
            e.preventDefault();
            const btn = e.target.closest('.copy-invitation-btn');
            const inviteId = btn.getAttribute('data-invite-id');
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            btn.disabled = true;
            
            fetch(`/google-oauth/invites/${inviteId}/invitation-text/`, {
                method: 'POST',
                headers: {
                    'X-CSRFToken': document.querySelector('[name=csrfmiddlewaretoken]').value,
                    'Content-Type': 'application/json',
                },
            })
            .then(response => response.json())
            .then(data => {
                if (data.success && data.invitation_text) {
                    navigator.clipboard.writeText(data.invitation_text).then(() => {
                        btn.innerHTML = '<i class="fas fa-check"></i>';
                        btn.classList.remove('btn-outline-warning');
                        btn.classList.add('btn-success');
                        
                        setTimeout(() => {
                            btn.innerHTML = originalText;
                            btn.classList.remove('btn-success');
                            btn.classList.add('btn-outline-warning');
                            btn.disabled = false;
                        }, 1500);
                    }).catch(err => {
                        console.error('Clipboard error:', err);
                        alert('Ошибка копирования в буфер обмена');
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    });
                } else {
                    alert('Ошибка получения текста инвайта');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Fetch error:', error);
                alert('Ошибка сети');
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        }
    });
});

</script>

